{
  "name": "tally-zero",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cache:build:delegates": "npx gov-tracker delegates --output data/delegate-cache.json",
    "cache:build:delegates:force": "npx gov-tracker delegates --output data/delegate-cache.json --force",
    "start": "npx serve@latest out",
    "audit:ci": "audit-ci --config ./audit-ci.jsonc",
    "lint": "eslint --fix .",
    "test": "npm run lint && tsc && vitest run",
    "prepare": "husky"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "plugins": [
      "prettier-plugin-organize-imports"
    ]
  },
  "lint-staged": {
    "*": [
      "prettier --ignore-unknown --write"
    ]
  },
  "dependencies": {
    "@gzeoneth/gov-tracker": "0.5.0-alpha.fix-refresh.3fdec9c",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^3.3.4",
    "@next/bundle-analyzer": "16.2.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reown/appkit": "^1.8.14",
    "@reown/appkit-adapter-wagmi": "^1.8.14",
    "@t3-oss/env-nextjs": "^0.10.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^1.1.2",
    "addreth": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "debug": "^4.4.3",
    "ethers": "^5",
    "geist": "^1.2.1",
    "lodash.shuffle": "^4.2.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "next-themes": "^0.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.49.3",
    "react-markdown": "^9.0.1",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "sonner": "^1.4.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "viem": "^2",
    "wagmi": "^2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/debug": "^4.1.12",
    "@types/lodash.shuffle": "^4.2.9",
    "@types/node": "^20.3.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "postcss": "^8",
    "prettier": "^3.2.5",
    "prettier-plugin-organize-imports": "^3.2.4",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "lodash": ">=4.18.0",
      "axios": ">=1.15.0",
      "defu": ">=6.1.5",
      "hono": ">=4.12.12"
    }
  }
}
